// ================================================================
//  I DID MY CHORES — Firestore Security Rules v3
//  Deploy with: firebase deploy --only firestore:rules
// ================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Households ──────────────────────────────────────────────
    // PUBLIC READ: Kids access the household by ID (via URL link from parent).
    // Household IDs are long Firebase UIDs — not guessable.
    // Only the authenticated parent (uid == householdId) can write.
    //
    // WHY: The kid dashboard has no auth session. Without public read,
    // Firestore denies the lookup and shows "Household not found" on any
    // device where the parent isn't logged in (e.g., a kid's iOS phone).
    match /households/{householdId} {
      allow read:  if true;                                        // Kids + parents can read
      allow write: if request.auth != null
                   && request.auth.uid == householdId;            // Only the parent can write
    }

    // ── Submissions ─────────────────────────────────────────────
    // PUBLIC CREATE: Kids submit chore completions without an auth session.
    // Read/update restricted to the authenticated household owner (parent).
    //
    // WHY: Kids use a PIN, not Google Auth. They must be able to create
    // submissions directly from the client. Write abuse is limited because
    // each submission requires a valid householdId that matches a real doc.
    match /submissions/{submissionId} {
      allow create: if true;                                       // Kids submit without auth
      allow read:   if request.auth != null;                      // Only parent can read
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.householdId;
      allow delete: if false;                                      // Never delete submissions
    }

    // ── Chore claims (concurrency control) ──────────────────────
    // Readable by anyone (kids need to see what's claimed).
    // Writable by Cloud Functions only (via Admin SDK) for atomic updates.
    // Client-side writes go through the claimChore Cloud Function.
    match /chore_claims/{claimId} {
      allow read:  if true;          // Kids need to see claims without auth
      allow write: if request.auth != null; // Cloud Function uses admin SDK
    }

    // ── Daily summaries ─────────────────────────────────────────
    // Read-only for authenticated parents.
    // Written only by Cloud Functions.
    match /daily_summaries/{summaryId} {
      allow read:  if request.auth != null;
      allow write: if false; // Cloud Functions only
    }

    // ── Payout records ──────────────────────────────────────────
    // Logged when a parent closes a pay period.
    // Only the authenticated parent can write or read their household's payouts.
    match /households/{householdId}/payouts/{payoutId} {
      allow read:  if request.auth != null && request.auth.uid == householdId;
      allow create: if request.auth != null && request.auth.uid == householdId;
      allow update, delete: if false; // Payouts are permanent records
    }

    // ── Photo hashes (fraud detection) ──────────────────────────
    // Written and read exclusively by Cloud Functions (Admin SDK).
    // Admin SDK bypasses these rules, so `if false` locks out all
    // browser clients — including authenticated parents — without
    // affecting the fraud-detection function.
    match /photo_hashes/{hash} {
      allow read, write: if false;
    }

    // ── Email subscribers ────────────────────────────────────────
    // Writing a doc here triggers the welcome email Cloud Function.
    // Only the admin account can create subscriber records;
    // never from anonymous client JS.
    match /subscribers/{email} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == "jmhodgefl@gmail.com";
    }

    // ── PIN brute-force rate limits ──────────────────────────────
    // Written and read exclusively by Cloud Functions (Admin SDK).
    // No client — authenticated or not — should touch this directly.
    match /pin_attempts/{key} {
      allow read, write: if false;
    }

    // ── Admin site content ──────────────────────────────────────
    match /admin/{docId} {
      allow read:  if true;  // Public content (pricing, hero text)
      allow write: if request.auth != null
                   && request.auth.token.email == "jmhodgefl@gmail.com";
    }
  }
}
